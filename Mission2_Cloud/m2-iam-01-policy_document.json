{
  "user": "devops-deploy-svc",
  "attached_policies": [
    {
      "PolicyName": "DevOpsDeploymentPolicy",
      "PolicyArn": "arn:aws:iam::123456789012:policy/DevOpsDeploymentPolicy",
      "AttachmentDate": "2023-11-15T14:22:00Z",
      "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Sid": "ECSDeployment",
            "Effect": "Allow",
            "Action": [
              "ecs:UpdateService",
              "ecs:DescribeServices",
              "ecs:RegisterTaskDefinition"
