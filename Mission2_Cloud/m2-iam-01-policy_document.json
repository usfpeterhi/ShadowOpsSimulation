            "Resource": [
              "arn:aws:s3:::prod-customer-exports",
              "arn:aws:s3:::prod-customer-exports/*",
              "arn:aws:s3:::deployment-artifacts",
              "arn:aws:s3:::deployment-artifacts/*"
            ]
          },
          {
            "Sid": "IAMFullAccess",
            "Effect": "Allow",
            "Action": "iam:*",
            "Resource": "*",
            "Note": "VIOLATION: Overly permissive - violates least privilege principle"
          },
          {
            "Sid": "EC2Launch",
            "Effect": "Allow",
            "Action": [
              "ec2:RunInstances",
              "ec2:DescribeInstances",
              "ec2:TerminateInstances"
            ],
            "Resource": "*"
          }
        ]
      }
    }
  ],
  "security_assessment": {
    "risk_level": "HIGH",
    "findings": [
      "IAM policy grants full iam:* permissions (least privilege violation)",
      "S3 permissions include access to prod-customer-exports bucket containing PII",
